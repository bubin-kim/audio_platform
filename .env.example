# 백엔드 환경변수 템플릿. 복사해서 backend/.env 로 쓴다.
# 경로·설정은 코드에 하드코딩하지 않고 여기서 읽는다(CLAUDE.md §5).

# DB URL — MVP는 SQLite. PostgreSQL 전환 시 이 값만 교체(P3).
# 예) postgresql+psycopg://user:pass@localhost:5432/audio_platform
DATABASE_URL=sqlite:////Users/bbin/Documents/audio_platform/audio_platform.db

# CORS 허용 오리진 (프론트 개발 서버)
CORS_ORIGINS=["http://localhost:3000"]

# 로컬 저장소 루트 (기본값: 저장소의 data/)
# DATA_DIR=/Users/bbin/Documents/audio_platform/data
